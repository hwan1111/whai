# =================================================================
# PostgreSQL 설정
# =================================================================
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=postgres_password_123
POSTGRES_DB_USER=postgres

# MLflow DB 사용자
MLFLOW_DB_USER=mlflow_user
MLFLOW_DB_PASSWORD=mlflow_password_123

# Airflow DB 사용자
AIRFLOW_DB_USER=airflow_user
AIRFLOW_DB_PASSWORD=airflow_password_123

# =================================================================
# Airflow 설정
# =================================================================
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Airflow 암호화 키 (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW_FERNET_KEY=your_fernet_key_here

# Airflow 시크릿 키
AIRFLOW__CORE__SECRET_KEY=your_secret_key_here

# Airflow API/UI 설정
# EC2 퍼블릭 IP 또는 도메인 (로컬 개발시 localhost:8081)
AIRFLOW__API__BASE_URL=http://your-ec2-ip:8081
# 또는 도메인 사용: http://airflow.yourdomain.com
AIRFLOW__API_AUTH__JWT_SECRET=whai-airflow-jwt-secret-2024

# Airflow 추가 패키지 설치
_PIP_ADDITIONAL_REQUIREMENTS=

# =================================================================
# MLflow 설정
# =================================================================
MLFLOW_FLASK_SERVER_SECRET_KEY=your_mlflow_secret_key_here

# MLflow 설정 파일 경로
MLFLOW_CONFIG_PATH=config/mlflow

# MLflow 추적 서버 URI (클라이언트에서 사용)
MLFLOW_TRACKING_URI=http://your-ec2-ip:5001

# MLflow 아티팩트 저장소 (로컬 또는 S3)
MLFLOW_ARTIFACTS_BUCKET=/app/mlflow-artifacts
# 또는 S3: s3://your-bucket/mlflow

# =================================================================
# AWS S3 설정 (MLflow 아티팩트용)
# =================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2

# =================================================================
# OpenRouter API 설정 (선택사항)
# =================================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =================================================================
# 백엔드 DB 설정 (Aiven MySQL)
# =================================================================
# 백엔드 SSL 인증서 경로
BACKEND_CERTS_PATH=config/backend/certs/ca.pem

# 애플리케이션용 DB 사용자 (읽기/쓰기만)
BACKEND_DB_USER=backend_app
BACKEND_DB_PASSWORD=secure_backend_password_123

# 관리용 DB 사용자 (마이그레이션, 스키마 변경)
BACKEND_ADMIN_USER=backend_admin
BACKEND_ADMIN_PASSWORD=secure_admin_password_456

# 서비스 데이터베이스 URL (애플리케이션용 - docker-compose 실행 시)
SERVICE_DATABASE_URL=mysql+pymysql://${BACKEND_DB_USER}:${BACKEND_DB_PASSWORD}@mysql-12676458-whai.b.aivencloud.com:16935/whai_service?ssl_ca=${BACKEND_CERTS_PATH}

# 마이그레이션/관리용 URL (초기 설정, 스키마 변경 시만 사용)
# MIGRATION_DATABASE_URL=mysql+pymysql://${BACKEND_ADMIN_USER}:${BACKEND_ADMIN_PASSWORD}@mysql-12676458-whai.b.aivencloud.com:16935/whai_service?ssl_ca=${BACKEND_CERTS_PATH}

# =================================================================
# 프론트엔드 설정
# =================================================================
# 백엔드 API URL (로컬: localhost:8000, EC2: your-ec2-ip:8000)
REACT_APP_API_URL=http://your-ec2-ip:8000