# 이 파일을 복사해서 .env.local로 만든 후 각자 값을 채워주세요
# cp .env.example .env.local

# 한국은행 ECOS API — https://ecos.bok.or.kr 에서 무료 회원가입 후 발급
BOK_API_KEY=

# KRX (한국거래소) — https://open.krx.co.kr 에서 무료 회원가입 후 발급
KRX_ID=
KRX_PW=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
AWS_S3_BUCKET=whai-profile-images

# Aiven MySQL 연결 정보
CA_PATH=           # 예: C:\Users\yourname\whai\config\certs\ca.pem

SERVICE_DATABASE_URL=mysql+pymysql://...?ssl_ca=${CA_PATH}
MLFLOW_DATABASE_URL=mysql+pymysql://...?ssl_ca=${CA_PATH}

# MLflow 원격 서버 (LLMOps)
# 예: http://mlflow.example.com:5001 또는 http://your-server.com:5001
MLFLOW_TRACKING_URI=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
MLFLOW_LOG_LEVEL=info
